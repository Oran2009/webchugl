{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "src/web",
    "rootDir": "src/web",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "typeRoots": ["src/web/types"]
  },
  "include": ["src/web/webchugl-esm.ts", "src/web/webchugl.ts", "src/web/types/**/*.d.ts"],
  "exclude": ["node_modules", "emsdk-*", "chuck", "chugl", "dist"]
}
